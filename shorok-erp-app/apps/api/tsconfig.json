{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "incremental": true,
    "noUncheckedIndexedAccess": false,
    "strictPropertyInitialization": false,
    "declaration": false
  },
  "include": ["src", "tests", "prisma"]
}
