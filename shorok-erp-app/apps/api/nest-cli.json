{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      { "include": "i18n/**/*.json", "outDir": "dist" },
      { "include": "modules/invoice-pdf/render.cjs", "outDir": "dist" }
    ]
  }
}
