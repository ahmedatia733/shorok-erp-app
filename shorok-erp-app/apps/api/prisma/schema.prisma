// Shorok ERP — Prisma schema
// Authoritative reference: ../specs/main/data-model.md
//
// All money columns are NUMERIC(14,2). Quantities are NUMERIC(14,4).
// Append-only tables (audit_logs, inventory_movements, order_collections,
// factory_ledger_entries) are protected by REVOKE UPDATE/DELETE in a
// follow-up migration. Non-negative inventory invariant is backed by a
// CHECK constraint also added in a follow-up migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================== Enums ===============================

enum Role {
  OWNER
  BRANCH_MANAGER
  WAREHOUSE
  ACCOUNTANT
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ProductCategory {
  NORMAL
  SPECIAL
}

enum MovementType {
  RECEIPT
  SALE
  ADJUSTMENT
  COUNT_CORRECTION
}

enum OrderStatus {
  DRAFT
  PENDING_PRICE_APPROVAL
  CONFIRMED
  PARTIALLY_COLLECTED
  PAID
  CANCELLED
}

enum PriceOverrideStatus {
  WITHIN_TOLERANCE
  PENDING_APPROVAL
  APPROVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CONFIRM
  CANCEL
  APPROVE
  COLLECT
  IMPORT
  LOGIN
  LOGOUT
}

enum PurchaseInvoiceStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum AccountCategory {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_SALES
  EXPENSE
}

enum AccountType {
  FIXED_ASSET
  CURRENT_ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_SALES
  EXPENSE
}

// =============================== Branch ==============================

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String   @unique @db.VarChar(120) @map("name_ar")
  nameEn    String   @unique @db.VarChar(120) @map("name_en")
  location  String?  @db.VarChar(240)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userAccesses          UserBranchAccess[]
  inventoryBalances     BranchInventoryBalance[]
  inventoryMovements    InventoryMovement[]
  customerOrders        CustomerOrder[]
  expenses              Expense[]
  purchaseInvoices      PurchaseInvoice[]    @relation("PurchaseInvoiceBranch")
  salesInvoices         SalesInvoice[]       @relation("SalesInvoiceBranch")

  @@map("branches")
}

// ================================ User ===============================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  name         String     @db.VarChar(120)
  phone        String     @unique @db.VarChar(20)
  email        String?    @unique @db.VarChar(160)
  passwordHash String     @map("password_hash") @db.VarChar(120)
  role         Role
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  branchAccesses    UserBranchAccess[]
  refreshTokens     RefreshToken[]
  inventoryWrites   InventoryMovement[] @relation("InventoryMovementCreatedBy")
  ordersCreated     CustomerOrder[]      @relation("CustomerOrderCreatedBy")
  pricesApproved    CustomerOrder[]      @relation("CustomerOrderPriceApprovedBy")
  collectionsCreated OrderCollection[]
  expensesCreated   Expense[]
  factoryEntries    FactoryLedgerEntry[]
  auditLogs         AuditLog[]
  journalEntries    JournalEntry[]       @relation("JournalEntryCreatedBy")
  purchaseInvoicesCreated PurchaseInvoice[] @relation("PurchaseInvoiceCreatedBy")
  salesInvoicesCreated    SalesInvoice[]   @relation("SalesInvoiceCreatedBy")
  payments                Payment[]
  journalTemplates        JournalTemplate[]
  customerTransactions    CustomerTransaction[]
  fixedAssets             FixedAsset[]         @relation("FixedAssetCreatedBy")
  depreciationEntries     DepreciationEntry[]  @relation("DepreciationEntryCreatedBy")

  @@map("users")
}

// ========================= PaymentAccount ============================

enum PaymentAccountType {
  CASH
  BANK

  @@map("payment_account_type")
}

enum PaymentEntityType {
  SUPPLIER
  CUSTOMER

  @@map("payment_entity_type")
}

model PaymentAccount {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(100)
  type      PaymentAccountType
  active    Boolean            @default(true)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  payments Payment[]
  customerTransactions CustomerTransaction[]

  @@map("payment_accounts")
}

// ============================ Payment ================================

model Payment {
  id               String            @id @default(uuid()) @db.Uuid
  entityType       PaymentEntityType @map("entity_type")
  entityId         String            @map("entity_id") @db.Uuid
  paymentAccountId String            @map("payment_account_id") @db.Uuid
  amount           Decimal           @db.Decimal(14, 2)
  paymentDate      DateTime          @map("payment_date") @db.Date
  referenceNumber  String?           @map("reference_number") @db.VarChar(100)
  notes            String?           @db.VarChar(500)
  createdBy        String            @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  paymentAccount PaymentAccount @relation(fields: [paymentAccountId], references: [id])
  creator        User           @relation(fields: [createdBy], references: [id])

  @@index([entityType, entityId])
  @@index([paymentAccountId])
  @@map("payments")
}

model UserBranchAccess {
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branch_access")
}

// ============================ RefreshToken ===========================

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(120)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userAgent  String?   @map("user_agent") @db.VarChar(240)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================== ProductSku ===========================

model ProductSku {
  id           String          @id @default(uuid()) @db.Uuid
  code         String          @unique @db.VarChar(60)
  colorNameAr  String          @db.VarChar(120) @map("color_name_ar")
  colorNameEn  String          @db.VarChar(120) @map("color_name_en")
  category     ProductCategory @default(NORMAL)
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  variants ProductVariant[]

  @@map("product_skus")
}

// =========================== ProductVariant ==========================

model ProductVariant {
  id                            String   @id @default(uuid()) @db.Uuid
  skuId                         String   @map("sku_id") @db.Uuid
  sizeMetersPerBoard            Decimal  @map("size_meters_per_board") @db.Decimal(10, 4)
  defaultSalePricePerMeter      Decimal  @map("default_sale_price_per_meter") @db.Decimal(14, 2)
  defaultPurchasePricePerMeter  Decimal  @map("default_purchase_price_per_meter") @db.Decimal(14, 2)
  priceOverrideTolerancePercent Decimal? @map("price_override_tolerance_percent") @db.Decimal(5, 2)
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sku                  ProductSku               @relation(fields: [skuId], references: [id], onDelete: Restrict)
  inventoryBalances    BranchInventoryBalance[]
  inventoryMovements   InventoryMovement[]
  customerOrders       CustomerOrder[]
  factoryEntries       FactoryLedgerEntry[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
  salesInvoiceLines    SalesInvoiceLine[]

  @@unique([skuId, sizeMetersPerBoard])
  @@index([skuId])
  @@map("product_variants")
}

// ============================== Supplier =============================

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String   @unique @db.VarChar(160) @map("name_ar")
  nameEn    String   @unique @db.VarChar(160) @map("name_en")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  factoryEntries FactoryLedgerEntry[]
  purchaseInvoices PurchaseInvoice[]

  @@map("suppliers")
}

// ====================== BranchInventoryBalance =======================

model BranchInventoryBalance {
  branchId         String    @map("branch_id") @db.Uuid
  productVariantId String    @map("product_variant_id") @db.Uuid
  boardsOnHand     Decimal   @default(0) @map("boards_on_hand") @db.Decimal(14, 4)
  metersOnHand     Decimal   @default(0) @map("meters_on_hand") @db.Decimal(14, 4)
  lastCountedAt    DateTime? @map("last_counted_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@id([branchId, productVariantId])
  @@map("branch_inventory_balances")
}

// ========================== InventoryMovement ========================

model InventoryMovement {
  id                String       @id @default(uuid()) @db.Uuid
  branchId          String       @map("branch_id") @db.Uuid
  productVariantId  String       @map("product_variant_id") @db.Uuid
  movementType      MovementType @map("movement_type")
  boardsQuantity    Decimal      @map("boards_quantity") @db.Decimal(14, 4)
  metersQuantity    Decimal      @map("meters_quantity") @db.Decimal(14, 4)
  referenceType     String?      @map("reference_type") @db.VarChar(40)
  referenceId       String?      @map("reference_id") @db.Uuid
  createdBy         String       @map("created_by") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  humanReadableNote String?      @map("human_readable_note") @db.Text

  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  creator        User           @relation("InventoryMovementCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([branchId, productVariantId, createdAt(sort: Desc)])
  @@map("inventory_movements")
}

// ============================ CustomerOrder ==========================

model CustomerOrder {
  id                       String              @id @default(uuid()) @db.Uuid
  branchId                 String              @map("branch_id") @db.Uuid
  orderDate                DateTime            @default(now()) @map("order_date") @db.Date
  customerName             String              @map("customer_name") @db.VarChar(160)
  productVariantId         String              @map("product_variant_id") @db.Uuid
  boardsQuantity           Decimal             @map("boards_quantity") @db.Decimal(14, 4)
  metersQuantity           Decimal             @map("meters_quantity") @db.Decimal(14, 4)
  salePricePerMeter        Decimal             @map("sale_price_per_meter") @db.Decimal(14, 2)
  priceOverrideStatus      PriceOverrideStatus @default(WITHIN_TOLERANCE) @map("price_override_status")
  priceApprovedByUserId    String?             @map("price_approved_by_user_id") @db.Uuid
  priceApprovedAt          DateTime?           @map("price_approved_at") @db.Timestamptz(6)
  requiredAmount           Decimal             @map("required_amount") @db.Decimal(14, 2)
  collectedAmount          Decimal             @default(0) @map("collected_amount") @db.Decimal(14, 2)
  remainingAmount          Decimal             @map("remaining_amount") @db.Decimal(14, 2)
  receiverName             String?             @map("receiver_name") @db.VarChar(160)
  status                   OrderStatus         @default(DRAFT)
  createdBy                String              @map("created_by") @db.Uuid
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  productVariant  ProductVariant   @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  creator         User             @relation("CustomerOrderCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  priceApprover   User?            @relation("CustomerOrderPriceApprovedBy", fields: [priceApprovedByUserId], references: [id], onDelete: SetNull)
  collections     OrderCollection[]

  @@index([branchId, orderDate(sort: Desc)])
  @@index([status])
  @@map("customer_orders")
}

// ========================== OrderCollection ==========================

model OrderCollection {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  collectedAt   DateTime @default(now()) @map("collected_at") @db.Timestamptz(6)
  amount        Decimal  @db.Decimal(14, 2)
  paidToAccount String?  @map("paid_to_account") @db.VarChar(120)
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order   CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  creator User          @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_collections")
}

// =============================== Expense =============================

model Expense {
  id                 String   @id @default(uuid()) @db.Uuid
  branchId           String   @map("branch_id") @db.Uuid
  expenseDate        DateTime @map("expense_date") @db.Date
  description        String   @db.VarChar(240)
  amount             Decimal  @db.Decimal(14, 2)
  paidFromAccount    String   @map("paid_from_account") @db.VarChar(120)
  glAccountId        String?  @map("gl_account_id") @db.Uuid
  paymentGlAccountId String?  @map("payment_gl_account_id") @db.Uuid
  journalEntryId     String?  @map("journal_entry_id") @db.Uuid
  createdBy          String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  branch           Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  creator          User          @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  glAccount        Account?      @relation("ExpenseGlAccount",        fields: [glAccountId],        references: [id])
  paymentGlAccount Account?      @relation("ExpensePaymentGlAccount", fields: [paymentGlAccountId], references: [id])
  journalEntry     JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([branchId, expenseDate(sort: Desc)])
  @@map("expenses")
}

// ======================== FactoryLedgerEntry =========================

model FactoryLedgerEntry {
  id                     String    @id @default(uuid()) @db.Uuid
  supplierId             String    @map("supplier_id") @db.Uuid
  orderDate              DateTime  @map("order_date") @db.Date
  productVariantId       String?   @map("product_variant_id") @db.Uuid
  boardsQuantity         Decimal?  @map("boards_quantity") @db.Decimal(14, 4)
  metersQuantity         Decimal?  @map("meters_quantity") @db.Decimal(14, 4)
  purchasePricePerMeter  Decimal?  @map("purchase_price_per_meter") @db.Decimal(14, 2)
  totalAmount            Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount             Decimal   @default(0) @map("paid_amount") @db.Decimal(14, 2)
  runningBalance         Decimal   @default(0) @map("running_balance") @db.Decimal(14, 2)
  notes                  String?   @db.Text
  createdBy              String    @map("created_by") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  supplier        Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  productVariant  ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  creator         User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([supplierId, orderDate])
  @@map("factory_ledger_entries")
}

// =============================== AuditLog ============================

model AuditLog {
  id                       String      @id @default(uuid()) @db.Uuid
  actorId                  String?     @map("actor_id") @db.Uuid
  action                   AuditAction
  entityType               String      @map("entity_type") @db.VarChar(60)
  entityId                 String?     @map("entity_id") @db.Uuid
  beforeSnapshot           Json?       @map("before_snapshot")
  afterSnapshot            Json?       @map("after_snapshot")
  humanReadableSummaryAr   String      @map("human_readable_summary_ar") @db.Text
  humanReadableSummaryEn   String      @map("human_readable_summary_en") @db.Text
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// =========================== SystemSettings ==========================

model SystemSettings {
  id                                       Int      @id @default(1)
  defaultPriceOverrideTolerancePercent     Decimal  @default(5.00) @map("default_price_override_tolerance_percent") @db.Decimal(5, 2)
  lowStockThresholdBoards                  Decimal  @default(5) @map("low_stock_threshold_boards") @db.Decimal(14, 4)
  createdAt                                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

// =========================== IdempotencyKey ==========================

model IdempotencyKey {
  key          String   @id @db.VarChar(120)
  method       String   @db.VarChar(10)
  path         String   @db.VarChar(240)
  responseHash String   @map("response_hash") @db.VarChar(120)
  responseBody Json     @map("response_body")
  statusCode   Int      @map("status_code")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ============================== Account ==============================

model Account {
  id          String          @id @default(uuid()) @db.Uuid
  code        String          @unique @db.VarChar(20)
  nameAr      String          @map("name_ar") @db.VarChar(160)
  nameEn      String          @map("name_en") @db.VarChar(160)
  category    AccountCategory
  accountType AccountType     @map("account_type")
  parentId    String?         @map("parent_id") @db.Uuid
  isLeaf      Boolean         @default(true) @map("is_leaf")
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  parent       Account?       @relation("AccountChildren", fields: [parentId], references: [id])
  children     Account[]      @relation("AccountChildren")
  journalLines JournalLine[]
  templateLines JournalTemplateLine[]
  fixedAssetsAsAsset      FixedAsset[] @relation("AssetAccount")
  fixedAssetsAsAccumDep   FixedAsset[] @relation("AccumulatedDepAccount")
  fixedAssetsAsDepExpense FixedAsset[] @relation("DepreciationExpenseAccount")
  expensesAsGl            Expense[]    @relation("ExpenseGlAccount")
  expensesAsPaymentGl     Expense[]    @relation("ExpensePaymentGlAccount")

  @@index([category])
  @@index([parentId])
  @@map("accounts")
}

// =========================== JournalEntry ============================

model JournalEntry {
  id            String    @id @default(uuid()) @db.Uuid
  entryNumber   BigInt    @unique @default(autoincrement()) @map("entry_number")
  entryType     String    @default("JOURNAL") @map("entry_type") @db.VarChar(30)
  reference     String?   @map("reference") @db.VarChar(100)
  entryDate     DateTime  @map("entry_date") @db.Date
  description   String    @db.VarChar(500)
  referenceType String?   @map("reference_type") @db.VarChar(60)
  referenceId   String?   @map("reference_id") @db.Uuid
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  creator  User          @relation("JournalEntryCreatedBy", fields: [createdBy], references: [id])
  lines    JournalLine[]
  expenses Expense[]

  @@index([entryDate(sort: Desc)])
  @@map("journal_entries")
}

// =========================== JournalLine =============================

model JournalLine {
  id             String  @id @default(uuid()) @db.Uuid
  journalEntryId String  @map("journal_entry_id") @db.Uuid
  accountId      String  @map("account_id") @db.Uuid
  debit          Decimal @default(0) @db.Decimal(14, 2)
  credit         Decimal @default(0) @db.Decimal(14, 2)
  note           String? @db.VarChar(300)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ========================= PurchaseInvoice ===========================

model PurchaseInvoice {
  id                 String                @id @default(uuid()) @db.Uuid
  invoiceNumber      String                @unique @map("invoice_number") @db.VarChar(30)
  invoiceDate        DateTime              @map("invoice_date") @db.Date
  dueDate            DateTime?             @map("due_date") @db.Date
  supplierId         String                @map("supplier_id") @db.Uuid
  branchId           String                @map("branch_id") @db.Uuid
  basedOn            String?               @map("based_on") @db.VarChar(300)
  docDirection       String?               @map("doc_direction") @db.VarChar(100)
  customsNumber      String?               @map("customs_number") @db.VarChar(100)
  notes              String?               @db.VarChar(1000)
  status             PurchaseInvoiceStatus @default(DRAFT)
  subtotal           Decimal               @default(0) @db.Decimal(14, 2)
  taxAmount          Decimal               @default(0) @map("tax_amount") @db.Decimal(14, 2)
  grandTotal         Decimal               @default(0) @map("grand_total") @db.Decimal(14, 2)
  apAccountId        String?               @map("ap_account_id") @db.Uuid
  taxAccountId       String?               @map("tax_account_id") @db.Uuid
  inventoryAccountId String?               @map("inventory_account_id") @db.Uuid
  journalEntryId     String?               @map("journal_entry_id") @db.Uuid
  createdBy          String                @map("created_by") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  branch   Branch   @relation("PurchaseInvoiceBranch", fields: [branchId], references: [id], onDelete: Restrict)
  creator  User     @relation("PurchaseInvoiceCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  lines    PurchaseInvoiceLine[]

  @@index([supplierId])
  @@index([branchId])
  @@index([invoiceDate(sort: Desc)])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id               String   @id @default(uuid()) @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  boardsQuantity   Decimal  @map("boards_quantity") @db.Decimal(14, 4)
  lengthM          Decimal? @map("length_m") @db.Decimal(14, 4)
  widthM           Decimal? @map("width_m") @db.Decimal(14, 4)
  metersQuantity   Decimal  @map("meters_quantity") @db.Decimal(14, 4)
  colorCode        String?  @map("color_code") @db.VarChar(20)
  heightM          Decimal? @map("height_m") @db.Decimal(14, 4)
  unitLabel        String?  @map("unit_label") @db.VarChar(30)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(14, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(14, 2)
  taxRate          Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount        Decimal  @default(0) @map("tax_amount") @db.Decimal(14, 2)
  isFree           Boolean  @default(false) @map("is_free")

  invoice        PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productVariant ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@map("purchase_invoice_lines")
}

// ========================= JournalTemplate ===========================

model JournalTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  active      Boolean  @default(true)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  creator User                  @relation(fields: [createdBy], references: [id])
  lines   JournalTemplateLine[]

  @@map("journal_templates")
}

// ======================= JournalTemplateLine =========================

model JournalTemplateLine {
  id         String   @id @default(uuid()) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  accountId  String   @map("account_id") @db.Uuid
  type       String   @db.VarChar(10)
  amount     Decimal? @db.Decimal(14, 2)
  note       String?  @db.VarChar(300)
  sortOrder  Int      @default(0) @map("sort_order")

  template JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account  Account         @relation(fields: [accountId], references: [id])

  @@index([templateId])
  @@map("journal_template_lines")
}

// =============================== Customer =============================

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique @db.VarChar(20)
  nameAr       String   @map("name_ar") @db.VarChar(200)
  phone        String?  @db.VarChar(30)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  transactions   CustomerTransaction[]
  salesInvoices  SalesInvoice[]

  @@map("customers")
}

// ========================= CustomerTransaction ========================

model CustomerTransaction {
  id               String   @id @default(uuid()) @db.Uuid
  customerId       String   @map("customer_id") @db.Uuid
  type             String   @db.VarChar(20)
  direction        String   @db.VarChar(2)
  amount           Decimal  @db.Decimal(14, 2)
  date             DateTime @db.Date
  reference        String?  @db.VarChar(100)
  description      String?  @db.VarChar(300)
  paymentAccountId String?  @map("payment_account_id") @db.Uuid
  createdBy        String   @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  customer       Customer        @relation(fields: [customerId], references: [id])
  paymentAccount PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  creator        User            @relation(fields: [createdBy], references: [id])

  @@index([customerId])
  @@index([customerId, date(sort: Asc)])
  @@map("customer_transactions")
}

// ========================= FixedAsset ================================

model FixedAsset {
  id                           String   @id @default(uuid()) @db.Uuid
  code                         String   @unique @db.VarChar(20)
  nameAr                       String   @map("name_ar") @db.VarChar(200)
  nameEn                       String   @default("") @map("name_en") @db.VarChar(200)
  acquisitionDate              DateTime @map("acquisition_date") @db.Date
  acquisitionCost              Decimal  @map("acquisition_cost") @db.Decimal(14, 2)
  salvageValue                 Decimal  @default(0) @map("salvage_value") @db.Decimal(14, 2)
  usefulLifeMonths             Int      @map("useful_life_months")
  depreciationMethod           String   @default("STRAIGHT_LINE") @map("depreciation_method") @db.VarChar(20)
  assetAccountId               String   @map("asset_account_id") @db.Uuid
  accumulatedDepAccountId      String   @map("accumulated_dep_account_id") @db.Uuid
  depreciationExpenseAccountId String   @map("depreciation_expense_account_id") @db.Uuid
  active                       Boolean  @default(true)
  notes                        String?  @db.VarChar(500)
  createdBy                    String   @map("created_by") @db.Uuid
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  assetAccount               Account   @relation("AssetAccount", fields: [assetAccountId], references: [id])
  accumulatedDepAccount      Account   @relation("AccumulatedDepAccount", fields: [accumulatedDepAccountId], references: [id])
  depreciationExpenseAccount Account   @relation("DepreciationExpenseAccount", fields: [depreciationExpenseAccountId], references: [id])
  creator                    User      @relation("FixedAssetCreatedBy", fields: [createdBy], references: [id])
  depreciationEntries        DepreciationEntry[]

  @@index([active])
  @@map("fixed_assets")
}

// ====================== DepreciationEntry ============================

model DepreciationEntry {
  id             String   @id @default(uuid()) @db.Uuid
  assetId        String   @map("asset_id") @db.Uuid
  periodDate     DateTime @map("period_date") @db.Date
  amount         Decimal  @db.Decimal(14, 2)
  journalEntryId String?  @map("journal_entry_id") @db.Uuid
  notes          String?  @db.VarChar(300)
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  asset   FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  creator User       @relation("DepreciationEntryCreatedBy", fields: [createdBy], references: [id])

  @@unique([assetId, periodDate])
  @@index([assetId])
  @@map("depreciation_entries")
}

// ========================= SalesInvoice ==============================

model SalesInvoice {
  id                  String    @id @default(uuid()) @db.Uuid
  invoiceNumber       BigInt    @unique @default(autoincrement()) @map("invoice_number")
  invoiceDate         DateTime  @map("invoice_date") @db.Date
  dueDate             DateTime? @map("due_date") @db.Date
  customerId          String    @map("customer_id") @db.Uuid
  branchId            String    @map("branch_id") @db.Uuid
  status              String    @default("DRAFT") @db.VarChar(20)
  notes               String?   @db.VarChar(1000)
  subtotal            Decimal   @default(0) @db.Decimal(14, 2)
  discountAmount      Decimal   @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxRate             Decimal   @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount           Decimal   @default(0) @map("tax_amount") @db.Decimal(14, 2)
  grandTotal          Decimal   @default(0) @map("grand_total") @db.Decimal(14, 2)
  totalCost           Decimal   @default(0) @map("total_cost") @db.Decimal(14, 2)
  arAccountId         String?   @map("ar_account_id") @db.Uuid
  revenueAccountId    String?   @map("revenue_account_id") @db.Uuid
  taxAccountId        String?   @map("tax_account_id") @db.Uuid
  cogsAccountId       String?   @map("cogs_account_id") @db.Uuid
  inventoryAccountId  String?   @map("inventory_account_id") @db.Uuid
  journalEntryId      String?   @map("journal_entry_id") @db.Uuid
  cogsJournalEntryId  String?   @map("cogs_journal_entry_id") @db.Uuid
  customerTxId        String?   @map("customer_tx_id") @db.Uuid
  createdBy           String    @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer  Customer         @relation(fields: [customerId], references: [id])
  branch    Branch           @relation("SalesInvoiceBranch", fields: [branchId], references: [id])
  creator   User             @relation("SalesInvoiceCreatedBy", fields: [createdBy], references: [id])
  lines     SalesInvoiceLine[]

  @@index([customerId])
  @@index([invoiceDate(sort: Desc)])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id               String   @id @default(uuid()) @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  quantity         Decimal  @db.Decimal(14, 4)
  unitLabel        String   @default("وحدة") @map("unit_label") @db.VarChar(30)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(14, 2)
  costPrice        Decimal  @default(0) @map("cost_price") @db.Decimal(14, 2)
  discountPct      Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(14, 2)
  lineCost         Decimal  @default(0) @map("line_cost") @db.Decimal(14, 2)
  note             String?  @db.VarChar(300)

  invoice        SalesInvoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([invoiceId])
  @@map("sales_invoice_lines")
}
