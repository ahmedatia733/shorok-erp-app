# Database
DATABASE_URL=postgresql://shorok:shorok@localhost:5432/shorok_erp?schema=public

# JWT secrets (override in production)
JWT_ACCESS_SECRET=dev-access-secret-please-replace
JWT_REFRESH_SECRET=dev-refresh-secret-please-replace
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Locales
DEFAULT_LOCALE=ar

# Ports
WEB_PORT=3000
API_PORT=3001

# API base URL consumed by apps/web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
